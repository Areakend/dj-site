rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'raphael.ohanian@telecomnancy.net';
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Global votes state - anyone can read, only admins can write
    match /votes/global_state {
      allow read: if true;  // Anyone can see vote counts
      allow write: if isAdmin();  // Only admins can reset votes or set now playing
    }
    
    // User votes - users can only read/write their own votes
    match /user_votes/{userId} {
      allow read: if true;  // Anyone can see who voted (for transparency)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();  // Only admins can delete user vote records
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
